{
  "app": "npx ts-node --prefer-ts-exts bin/infrastructure.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.d.ts", "**/*.js", "tsconfig.json", "package*.json", "yarn.lock", "node_modules", "dist", "cdk.out"]
  },
  "context": {
    "githubOwner": "YOUR_GITHUB_USERNAME",
    "githubConnectionArn": "arn:aws:codestar-connections:us-east-1:YOUR_ACCOUNT:connection/YOUR_CONNECTION_ID",
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:stackRelativeExports": true,
    "@aws-cdk/aws-rds:databaseClusterSnapshotRestoreProps": true
  }
}
